{
    "name": "ssr-micro-vue2",
    "version": "1.0.0",
    "exports": {
        "./*": {
            "types": "./src/*.d.ts",
            "default": "./src/*.ts"
        }
    },
    "esmx": {
        "entry": {
            "client": "./src/entry.client.ts",
            "server": "./src/entry.server.ts"
        },
        "exports": {
            "./vue-server-renderer": {
                "server": "./src/server-renderer.ts",
                "client": false
            },
            "./routes": "./src/routes.ts"
        },
        "uses": [
            "ssr-micro-shared"
        ],
        "provides": [
            "vue"
        ]
    },
    "description": "Vue2 micro-app for micro-frontend example",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "esmx dev",
        "build": "esmx build",
        "preview": "esmx preview",
        "start": "esmx start",
        "lint:type": "vue-tsc --noEmit",
        "build:type": "vue-tsc --declaration --emitDeclarationOnly --noEmit false --outDir dist/src && tsc-alias -p tsconfig.json --outDir dist/src",
        "build:dts": "vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist --rootDir ."
    },
    "dependencies": {
        "@esmx/core": "workspace:*"
    },
    "devDependencies": {
        "tsc-alias": "^1.8.17",
        "@esmx/rspack-vue": "workspace:*",
        "@esmx/router": "workspace:*",
        "@esmx/router-vue": "workspace:*",
        "@types/node": "^25.6.2",
        "ssr-micro-shared": "workspace:*",
        "typescript": "6.0.3",
        "unhead": "^3.1.3",
        "vue": "2.7.16",
        "vue-server-renderer": "2.7.16",
        "vue-tsc": "^3.2.8"
    }
}
