{
    "name": "ssr-micro-rsbuild-react",
    "version": "1.0.0",
    "exports": {
        "./*": {
            "types": "./src/*.d.ts",
            "default": "./src/*.ts"
        }
    },
    "esmx": {
        "entry": {
            "client": "./src/entry.client.ts",
            "server": "./src/entry.server.ts"
        },
        "exports": {
            "./routes": "./src/routes.ts"
        },
        "uses": [
            "ssr-micro-shared",
            "ssr-micro-react-shared"
        ]
    },
    "description": "React micro-app (Rsbuild) for micro-frontend example",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "esmx dev",
        "build": "esmx build",
        "preview": "esmx preview",
        "start": "esmx start",
        "lint:type": "tsc --noEmit",
        "build:dts": "tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist --rootDir ."
    },
    "dependencies": {
        "@esmx/core": "workspace:*"
    },
    "devDependencies": {
        "@esmx/router": "workspace:*",
        "@esmx/router-react": "workspace:*",
        "@esmx/rsbuild-react": "workspace:*",
        "@types/node": "^25.6.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@unhead/react": "^3.1.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "ssr-micro-react-shared": "workspace:*",
        "ssr-micro-shared": "workspace:*",
        "typescript": "6.0.3",
        "unhead": "^3.1.3"
    }
}
