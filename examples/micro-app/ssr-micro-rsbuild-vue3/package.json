{
    "name": "ssr-micro-rsbuild-vue3",
    "version": "1.0.0",
    "exports": {
        "./*": {
            "types": "./src/*.d.ts",
            "default": "./src/*.ts"
        }
    },
    "esmx": {
        "entry": {
            "client": "./src/entry.client.ts",
            "server": "./src/entry.server.ts"
        },
        "exports": {
            "./routes": "./src/routes.ts"
        },
        "uses": [
            "ssr-micro-shared",
            "ssr-micro-vue3-shared"
        ]
    },
    "description": "Vue3 micro-app (Rsbuild) for micro-frontend example",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "esmx dev",
        "build": "esmx build",
        "preview": "esmx preview",
        "start": "esmx start",
        "lint:type": "vue-tsc --noEmit",
        "build:type": "vue-tsc --declaration --emitDeclarationOnly --noEmit false --outDir dist/src && tsc-alias -p tsconfig.json --outDir dist/src",
        "build:dts": "vue-tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist --rootDir ."
    },
    "dependencies": {
        "@esmx/core": "workspace:*"
    },
    "devDependencies": {
        "@esmx/router": "workspace:*",
        "@esmx/router-vue": "workspace:*",
        "@esmx/rsbuild-vue": "workspace:*",
        "@types/node": "^25.6.2",
        "@unhead/vue": "^3.1.0",
        "@vue/server-renderer": "^3.5.34",
        "ssr-micro-shared": "workspace:*",
        "ssr-micro-vue3-shared": "workspace:*",
        "tsc-alias": "^1.8.17",
        "typescript": "6.0.3",
        "unhead": "^3.1.3",
        "vue": "^3.5.34",
        "vue-tsc": "^3.2.8"
    }
}
