{
    "name": "ssr-micro-shared",
    "version": "1.0.0",
    "esmx": {
        "entry": {
            "client": "./src/entry.client.ts",
            "server": "./src/entry.server.ts"
        },
        "provides": [
            "@esmx/router",
            "unhead"
        ],
        "exports": {
            "./index": "./src/index.ts"
        }
    },
    "description": "Shared modules for micro-frontend example",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "esmx dev",
        "build": "esmx build",
        "preview": "esmx preview",
        "start": "esmx start",
        "build:dts": "tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist --rootDir ."
    },
    "dependencies": {
        "@esmx/core": "workspace:*"
    },
    "devDependencies": {
        "@esmx/router": "workspace:*",
        "@esmx/rspack": "workspace:*",
        "@types/node": "^25.6.2",
        "typescript": "6.0.3",
        "unhead": "^3.1.3"
    },
    "exports": {
        "./*": {
            "types": "./src/*.d.ts",
            "default": "./src/*.ts"
        }
    }
}
