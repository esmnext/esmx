{
    "name": "ssr-micro-lit",
    "version": "1.0.0",
    "exports": {
        "./*": {
            "types": "./src/*.d.ts",
            "default": "./src/*.ts"
        }
    },
    "esmx": {
        "entry": {
            "client": "./src/entry.client.ts",
            "server": "./src/entry.server.ts"
        },
        "exports": {
            "./routes": "./src/routes.ts"
        },
        "uses": [
            "ssr-micro-shared"
        ]
    },
    "description": "Lit micro-app for micro-frontend example",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "esmx dev",
        "build": "esmx build",
        "preview": "esmx preview",
        "start": "esmx start",
        "lint:type": "tsc --noEmit",
        "build:dts": "tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist --rootDir ."
    },
    "dependencies": {
        "@esmx/core": "workspace:*"
    },
    "peerDependencies": {
        "unhead": "^3.1.3"
    },
    "devDependencies": {
        "@esmx/rspack": "workspace:*",
        "@esmx/router": "workspace:*",
        "@lit-labs/ssr": "^4.1.0",
        "@lit-labs/ssr-client": "^1.1.8",
        "@types/node": "^25.6.2",
        "lit": "^3.3.0",
        "ssr-micro-shared": "workspace:*",
        "typescript": "6.0.3"
    }
}
