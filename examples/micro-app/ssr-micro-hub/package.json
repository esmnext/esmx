    "devDependencies": {
        "@esmx/router": "workspace:*",
        "@esmx/rspack": "workspace:*",
        "@types/node": "^25.6.2",
        "ssr-micro-html": "workspace:*",
        "ssr-micro-lit": "workspace:*",
        "ssr-micro-preact": "workspace:*",
        "ssr-micro-preact-htm": "workspace:*",
        "ssr-micro-preact-shared": "workspace:*",
        "ssr-micro-react": "workspace:*",
        "ssr-micro-react-shared": "workspace:*",
        "ssr-micro-rsbuild-html": "workspace:*",
        "ssr-micro-rsbuild-react": "workspace:*",
        "ssr-micro-rsbuild-vue3": "workspace:*",
        "ssr-micro-shared": "workspace:*",
        "ssr-micro-solid": "workspace:*",
        "ssr-micro-svelte": "workspace:*",
        "ssr-micro-vite-html": "workspace:*",
        "ssr-micro-vite-react": "workspace:*",
        "ssr-micro-vite-vue3": "workspace:*",
        "ssr-micro-vue2": "workspace:*",
        "ssr-micro-vue3": "workspace:*",
        "ssr-micro-vue3-shared": "workspace:*",
        "typescript": "6.0.3"
    }
