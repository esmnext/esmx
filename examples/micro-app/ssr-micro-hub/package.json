{
    "name": "ssr-micro-hub",
    "version": "1.0.0",
    "esmx": {
        "entry": {
            "client": "./src/entry.client.ts",
            "server": "./src/entry.server.ts"
        },
        "uses": [
            "ssr-micro-shared",
            "ssr-micro-vue3-shared",
            "ssr-micro-html",
            "ssr-micro-lit",
            "ssr-micro-preact",
            "ssr-micro-preact-htm",
            "ssr-micro-react",
            "ssr-micro-solid",
            "ssr-micro-svelte",
            "ssr-micro-vue2",
            "ssr-micro-vue3",
            "ssr-micro-vite-html",
            "ssr-micro-vite-react",
            "ssr-micro-vite-vue3",
            "ssr-micro-rsbuild-html",
            "ssr-micro-rsbuild-react",
            "ssr-micro-rsbuild-vue3",
            "ssr-micro-react-shared",
            "ssr-micro-preact-shared"
        ]
    },
    "description": "Hub for micro-frontend example",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "esmx dev",
        "build": "esmx build",
        "preview": "esmx preview",
        "start": "esmx start",
        "lint:type": "tsc --noEmit"
    },
    "dependencies": {
        "@esmx/core": "workspace:*"
    },
    "peerDependencies": {
        "preact": "^10.29.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "solid-js": "^1.9.12",
