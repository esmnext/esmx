{
    "name": "ssr-micro-preact-shared",
    "version": "1.0.0",
    "esmx": {
        "entry": {
            "client": "./src/entry.client.ts",
            "server": "./src/entry.server.ts"
        },
        "provides": [
            "preact",
            "preact-render-to-string"
        ]
    },
    "description": "Shared Preact runtime for the micro-frontend example: single authoritative provider of preact, consumed by the preact apps via uses (no per-app provides, no multi-candidate election)",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "esmx dev",
        "build": "esmx build",
        "preview": "esmx preview",
        "start": "esmx start",
        "build:dts": "tsc -p tsconfig.json --declaration --emitDeclarationOnly --outDir dist --rootDir ."
    },
    "dependencies": {
        "@esmx/core": "workspace:*"
    },
    "devDependencies": {
        "@esmx/rspack": "workspace:*",
        "@types/node": "^25.6.2",
        "preact": "^10.29.1",
        "preact-render-to-string": "^6.6.7",
        "typescript": "6.0.3"
    },
    "exports": {
        "./*": {
            "types": "./src/*.d.ts",
            "default": "./src/*.ts"
        }
    }
}
