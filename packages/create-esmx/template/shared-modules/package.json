{
    "name": "{{projectName}}",
    "version": "1.0.0",
    "esmx": {
        "entry": {
            "client": "./src/entry.client.ts",
            "server": "./src/entry.server.ts"
        },
        "exports": {
            "./vue/index": "./src/vue/index.ts",
            "./vue2/index": "./src/vue2/index.ts"
        },
        "provides": [
            "@esmx/router",
            "@esmx/router-vue",
            "vue",
            "vue2"
        ]
    },
    "description": "Shared modules solution for micro-frontend architecture",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "esmx dev",
        "build": "esmx build",
        "preview": "esmx preview",
        "start": "esmx start",
        "lint:type": "tsc --noEmit",
        "build:type": "tsc --declaration --emitDeclarationOnly --outDir dist/src && tsc-alias -p tsconfig.json --outDir dist/src"
    },
    "dependencies": {
        "@esmx/core": "{{esmxVersion}}"
    },
    "devDependencies": {
        "vue": "^3.5.23",
        "@esmx/router": "{{esmxVersion}}",
        "@esmx/router-vue": "{{esmxVersion}}",
        "vue2": "npm:vue@2.7.16",
        "tsc-alias": "^1.8.16",
        "@esmx/rspack": "{{esmxVersion}}",
        "@types/node": "^24.10.0",
        "typescript": "5.9.3"
    }
}
